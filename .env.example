# ── GitHub App ────────────────────────────────────────────────────────────────
# Get these from GitHub → Settings → Developer settings → GitHub Apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./pr_warden.pem
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file in project root. Single-user bot doesn't need a real DB server.
DATABASE_URL=sqlite+aiosqlite:///./pr_warden.db

# ── Anthropic (Week 3) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Cost caps ─────────────────────────────────────────────────────────────────
SUMMARIZER_MAX_COST_USD=0.10
DAILY_COST_LIMIT_USD=5.00

# ── Semgrep ruleset (optional overrides; empty → curated defaults) ──────────────
# Comma-separated Semgrep packs to run. Default:
#   p/security-audit,p/secrets,p/owasp-top-ten,p/cwe-top-25
SEMGREP_CONFIGS=
# Comma-separated check_id substrings to suppress. Default drops noisy
# presence-detectors: avoid-pickle,exec-detected,eval-detected
SEMGREP_EXCLUDE_RULES=

# ── Stats endpoint ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STATS_BEARER_TOKEN=

# ── Slash commands ────────────────────────────────────────────────────────────
# Only this GitHub username's /pr_warden commands are honored
BOT_OWNER_USERNAME=
