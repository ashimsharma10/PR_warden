# ── GitHub App ────────────────────────────────────────────────────────────────
# Get these from GitHub → Settings → Developer settings → GitHub Apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./pr_warden.pem
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file in project root. Single-user bot doesn't need a real DB server.
DATABASE_URL=sqlite+aiosqlite:///./pr_warden.db

# ── Anthropic (Week 3) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Cost caps ─────────────────────────────────────────────────────────────────
SUMMARIZER_MAX_COST_USD=0.10
DAILY_COST_LIMIT_USD=5.00

# ── Review agent (off by default) ───────────────────────────────────────────────
# Comma-separated owner/name allowlist. Empty → the agent never runs, so
# deploying changes nothing until a repo is added here.
AGENT_REVIEW_REPOS=
AGENT_MODEL=claude-sonnet-4-6
AGENT_TIMEOUT_S=90

# ── Stats endpoint ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STATS_BEARER_TOKEN=

# ── Slash commands ────────────────────────────────────────────────────────────
# Only this GitHub username's /pr_warden commands are honored
BOT_OWNER_USERNAME=
